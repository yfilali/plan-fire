# ── Firly environment ───────────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored. On Vercel, set these in
# Project → Settings → Environment Variables instead (DATABASE_URL is injected
# automatically by the Neon integration).

# ── Database (Neon Postgres) ──
# From the Neon integration in Vercel, or the Neon dashboard. Use the POOLED
# connection string (host contains "-pooler") for serverless.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Auth (Better Auth) ──
# A long random secret. Generate one: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-with-32+-random-bytes
# The app's public origin. Local: http://localhost:8089  Prod: https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:8089

# ── Transactional email (Resend) ──
# Needed for email verification + password reset. Without it, links are logged
# to the server console (fine for local dev only).
RESEND_API_KEY=re_...
EMAIL_FROM=Firly <noreply@yourdomain.com>

# ── Social login ──
# Google: console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook: developers.facebook.com → your app → Facebook Login → Settings.
# Valid OAuth Redirect URI: <BETTER_AUTH_URL>/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── AI co-pilot (optional) ──
# https://console.anthropic.com → Settings → API Keys. Unset → offline demo mode.
ANTHROPIC_API_KEY=

# ── Billing (Stripe, optional) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_LIFETIME=
